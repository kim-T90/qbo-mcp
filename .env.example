# QuickBooks Online MCP — Environment Variables
# Copy to .env and fill in your values.
# Run `uv run python -m quickbooks_mcp.auth` to complete OAuth and populate tokens.

# ── Required ─────────────────────────────────────────────────────────────────

# OAuth app credentials from https://developer.intuit.com
QBO_CLIENT_ID=your_client_id
QBO_CLIENT_SECRET=your_client_secret

# OAuth refresh token — auto-rotated by the server on each token refresh.
# Initial value comes from the auth flow. Do not edit manually.
QBO_REFRESH_TOKEN=stored_refresh_token

# QBO Company (Realm) ID — identifies which QuickBooks company to connect to.
# Shown in the auth flow output and in the QBO URL: .../app/homepage?companyId=XXXXX
QBO_REALM_ID=your_company_id

# ── Optional (with defaults) ─────────────────────────────────────────────────

# API environment: "sandbox" for testing, "production" for real data.
# Default: sandbox
QBO_ENVIRONMENT=sandbox

# Redirect URI registered on your Intuit app.
# Required for production. Optional for sandbox because the auth CLI falls back
# to the Intuit OAuth Playground when this is left blank.
QBO_REDIRECT_URI=

# QBO API minor version. Controls which API features are available.
# Default: 75 (latest as of March 2026)
QBO_MINOR_VERSION=75

# Debug mode: logs raw API request/response payloads to stderr.
# Useful for diagnosing Business Validation Errors. Never logs tokens.
# Default: false
DEBUG_QBO=false
